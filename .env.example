DISCORD_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Choose one: gemini (default) or openai
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI (only used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

WINDOW_HOURS=24
MAX_MESSAGES_PER_CHANNEL=180
MAX_MESSAGES_FOR_LLM_PER_CHANNEL=60
# Optional: stop daily runs after this KST date (YYYY-MM-DD)
RUN_UNTIL_DATE=
SEND_ONCE_PER_DAY=true
SEND_STATE_FILE=.state/last_sent_date_kst.txt
SEND_NOT_BEFORE_KST=09:30
FORCE_SEND=false

# Optional: override default channels JSON
# DISCORD_CHANNELS_JSON=[{"id":"1447614842394509452","label":"general-chat","url":"https://discord.com/channels/1374314257096900640/1447614842394509452"}]
